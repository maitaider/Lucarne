# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase
supabase/.branches
supabase/.temp
supabase/.env
# types.generated.ts IS committed so the GitHub-integration build (which can't
# run `db:types`) is self-contained. Regenerate with `pnpm db:types` after
# migrations and commit the result.

# OS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Local Claude Code tooling state (plans, session config)
.claude/
