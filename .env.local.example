# =============================================================================
# Lucarne — Environment variables
# Copy to .env.local and fill in the values.
# =============================================================================

# Supabase — local default (after `pnpm supabase start`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...   # printed by `supabase start`
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...        # printed by `supabase start` (server only)

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — football data (Sprint 1)
API_FOOTBALL_KEY=
FOOTBALL_DATA_KEY=

# Optional — rate limiting (Sprint 2)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — email (Sprint 4)
RESEND_API_KEY=

# Cron secret (protect /api/cron/*)
CRON_SECRET=

# -----------------------------------------------------------------------------
# Stripe (optional but required for /profile/wallet "Buy tokens" flow)
# Without these set, the BuyTokensCard renders disabled with a hint.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...  # from `stripe listen` or Stripe Dashboard

# -----------------------------------------------------------------------------
# Hermes news agent (POST /api/hermes/news)
# Generate a long random string (e.g. `openssl rand -hex 32`) and share with
# the agent. The endpoint rejects requests without `Authorization: Bearer ...`.
# -----------------------------------------------------------------------------
HERMES_API_TOKEN=
